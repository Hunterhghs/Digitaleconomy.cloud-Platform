# --- Database ---
# SQLite for local dev. For production swap to a Postgres connection string and
# update prisma/schema.prisma `provider` to "postgresql".
DATABASE_URL="file:./dev.db"

# --- Auth.js ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="dev-only-secret-change-me-in-production-please"
NEXTAUTH_URL="http://localhost:3000"

# --- Storage (R2 / S3) ---
# When unset, the platform falls back to local filesystem storage in
# ./storage/local. For production (Cloudflare etc.) set STORAGE_DRIVER=s3 and
# implement the S3 path in src/lib/storage.ts.
STORAGE_DRIVER="local" # "local" | "s3"
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_ENDPOINT="" # set for R2; leave blank for AWS S3

# --- Uploads ---
UPLOAD_MAX_BYTES="52428800" # 50 MB

# --- Chain (optional, dormant in the nonprofit phase) ---
# When CHAIN_ENABLED=false (default), no on-chain mints happen on download.
# Set to true + provide contract addresses + RPC + relayer key to re-enable
# the on-chain receipt layer (see contracts/README.md).
CHAIN_ENABLED="false"
CHAIN_NAME="base-sepolia" # "base" | "base-sepolia"
CHAIN_RPC_URL=""
RECEIPT_CONTRACT_ADDRESS=""
NATIVE_NFT_CONTRACT_ADDRESS=""
RELAYER_PRIVATE_KEY=""

# --- Platform ---
PLATFORM_NAME="Digitaleconomy.cloud"
PLATFORM_ADMIN_EMAIL="admin@example.com"
PLATFORM_ADMIN_PASSWORD="admin1234"
