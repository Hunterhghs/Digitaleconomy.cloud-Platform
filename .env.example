# --- Database ---
# SQLite for local dev. For production, swap to a Postgres connection string and
# update prisma/schema.prisma `provider` to "postgresql".
DATABASE_URL="file:./dev.db"

# --- Auth.js ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="dev-only-secret-change-me-in-production-please"
NEXTAUTH_URL="http://localhost:3000"

# --- Stripe ---
# Get from https://dashboard.stripe.com/test/apikeys
# When unset, the platform falls back to a SIMULATED Stripe path that
# auto-completes orders for local demos.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# --- Storage (R2 / S3) ---
# When unset, the platform falls back to local filesystem storage in ./storage/local
# For production, set these to point at a private R2 or S3 bucket.
STORAGE_DRIVER="local" # "local" | "s3"
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_ENDPOINT="" # set for R2; leave blank for AWS S3

# --- Chain (Base / Base Sepolia) ---
# When CHAIN_ENABLED=false, mints are SIMULATED and recorded as fake tx hashes
# in the database so the full UX works without a real chain connection.
CHAIN_ENABLED="false"
CHAIN_NAME="base-sepolia" # "base" | "base-sepolia"
CHAIN_RPC_URL=""
RECEIPT_CONTRACT_ADDRESS=""
NATIVE_NFT_CONTRACT_ADDRESS=""
RELAYER_PRIVATE_KEY="" # hot key for the gas relayer; use a secrets manager in prod
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=""

# --- Platform ---
PLATFORM_NAME="Digitaleconomy.cloud"
PLATFORM_ADMIN_EMAIL="admin@example.com"
PLATFORM_ADMIN_PASSWORD="admin1234"
