# --- Database (Postgres) ---
# Recommended: Neon (free tier) - either via Vercel's Storage tab integration
# or directly at https://neon.tech
#   DATABASE_URL  = pooled connection string (used at runtime)
#   DIRECT_URL    = unpooled connection string (used by `prisma db push` / migrate)
#
# When Vercel auto-injects POSTGRES_PRISMA_URL + POSTGRES_URL_NON_POOLING,
# alias them to DATABASE_URL + DIRECT_URL respectively in your Vercel env vars.
DATABASE_URL="postgres://user:password@host.neon.tech/digitaleconomy?sslmode=require"
DIRECT_URL="postgres://user:password@host.neon.tech/digitaleconomy?sslmode=require"

# --- Auth.js ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="dev-only-secret-change-me-in-production-please"
NEXTAUTH_URL="http://localhost:3000"

# --- Storage ---
# Local dev writes to ./storage/local. On Vercel/serverless this won't work
# for new uploads (read-only filesystem), so /upload auto-disables - see
# UPLOADS_ENABLED below.
STORAGE_DRIVER="local" # "local" | "s3"
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_ENDPOINT="" # set for R2; leave blank for AWS S3

# --- Uploads ---
# Auto-detected: enabled when STORAGE_DRIVER=local AND not on Vercel.
# Force on/off explicitly: UPLOADS_ENABLED=true | false
# UPLOADS_ENABLED=""
UPLOAD_MAX_BYTES="52428800" # 50 MB

# --- Chain (optional, dormant in the nonprofit phase) ---
CHAIN_ENABLED="false"
CHAIN_NAME="base-sepolia" # "base" | "base-sepolia"
CHAIN_RPC_URL=""
RECEIPT_CONTRACT_ADDRESS=""
NATIVE_NFT_CONTRACT_ADDRESS=""
RELAYER_PRIVATE_KEY=""

# --- Platform ---
PLATFORM_NAME="Digitaleconomy.cloud"
PLATFORM_ADMIN_EMAIL="admin@example.com"
PLATFORM_ADMIN_PASSWORD="admin1234"
